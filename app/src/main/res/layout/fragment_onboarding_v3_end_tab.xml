<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent">

    <com.codebasetemplate.features.feature_onboarding.ui.v1.FitWidthImageView
        android:layout_width="match_parent"
        android:adjustViewBounds="true"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:scaleType="fitCenter"
        android:id="@+id/ivIntroduction"
        tools:src="@drawable/intro_31"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.core.ads.customviews.ads.BannerNativeContainerLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/layoutBannerNative"
            android:visibility="gone"
            android:layout_marginBottom="70dp"
            android:layout_gravity="bottom"
            android:orientation="vertical" />

        <View
            android:background="@drawable/bg_intro_text_dark"
            android:layout_width="match_parent"
            android:layout_height="180dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/_50dp"
            android:text="@string/core_onboarding_title_3"
            android:textAllCaps="true"
            android:id="@+id/tvTitle"
            android:textColor="@color/white"
            android:textSize="@dimen/_24dp"
            android:gravity="center"
            android:layout_marginHorizontal="@dimen/_10dp"
            android:layout_height="wrap_content"/>

    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_gravity="bottom"
        android:layout_marginBottom="@dimen/_40dp"
        android:layout_height="70dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="match_parent"
            android:textColor="#fff"
            android:background="@drawable/bg_intro_get_started_button"
            android:layout_gravity="end|bottom"
            android:textSize="@dimen/_16dp"
            android:id="@+id/btGetStart"
            android:gravity="center"
            android:textAllCaps="false"
            android:paddingVertical="@dimen/_10dp"
            android:paddingHorizontal="@dimen/_10dp"
            android:layout_marginHorizontal="@dimen/_20dp"
            android:text="@string/core_onboarding_action_get_start"
            android:fontFamily="@font/roboto_medium"
            android:layout_height="wrap_content"/>
    </FrameLayout>

</FrameLayout>
