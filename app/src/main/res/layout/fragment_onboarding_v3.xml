<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white"
        android:orientation="vertical">

        <com.codebasetemplate.features.feature_onboarding.ui.v1.FitWidthImageViewV2
            android:id="@+id/iv_introduction"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            style="@style/RoundOnboardingV3"
            android:background="@color/white"
            android:scaleType="fitCenter"
            tools:src="@drawable/intro_31" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_gravity="bottom"
            android:layout_height="wrap_content">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_alignParentBottom="true"
                android:visibility="visible"
                android:background="@drawable/bg_white_round_top"
                android:id="@+id/topNext"
                android:layout_height="60dp">
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_gravity="center_horizontal|bottom"
                    android:layout_marginBottom="@dimen/_25dp"
                    android:layout_height="wrap_content">
                    <View
                        android:layout_width="@dimen/_8dp"
                        android:id="@+id/indicator11"
                        android:layout_height="@dimen/_8dp"
                        android:background="@drawable/bg_intro_dot_selected"/>

                    <View
                        android:id="@+id/indicator22"
                        android:layout_width="@dimen/_8dp"
                        android:layout_height="@dimen/_8dp"
                        android:layout_marginHorizontal="@dimen/_10dp"
                        android:background="@drawable/bg_intro_dot_selected"/>

                    <View
                        android:id="@+id/indicator33"
                        android:layout_width="@dimen/_8dp"
                        android:layout_height="@dimen/_8dp"
                        android:background="@drawable/bg_intro_dot_selected"/>
                </androidx.appcompat.widget.LinearLayoutCompat>

                <TextView
                    android:layout_width="wrap_content"
                    android:textColor="#9747FF"
                    android:layout_gravity="end|bottom"
                    android:layout_marginBottom="@dimen/_17dp"
                    android:layout_marginEnd="@dimen/_10dp"
                    android:textSize="@dimen/_16dp"
                    android:paddingVertical="@dimen/_3dp"
                    android:paddingHorizontal="@dimen/_12dp"
                    android:id="@+id/tvNextTop"
                    android:background="@drawable/bg_transparent_ripple_media_shape"
                    android:text="@string/common_next"
                    android:fontFamily="@font/roboto_medium"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
            <FrameLayout
                android:layout_width="match_parent"
                android:id="@+id/frameAds"
                android:background="@color/white"
                android:layout_height="wrap_content">
                <com.core.ads.customviews.ads.BannerNativeContainerLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/layoutBannerNative"
                    android:visibility="visible"
                    android:orientation="vertical" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_alignParentBottom="true"
                android:visibility="visible"
                android:id="@+id/bottomNext"
                android:background="@color/white"
                android:layout_height="60dp">
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_gravity="center_horizontal|bottom"
                    android:layout_marginBottom="@dimen/_25dp"
                    android:layout_height="wrap_content">
                    <View
                        android:layout_width="@dimen/_8dp"
                        android:id="@+id/indicator1"
                        android:layout_height="@dimen/_8dp"
                        android:background="@drawable/bg_intro_dot_selected"/>

                    <View
                        android:id="@+id/indicator2"
                        android:layout_width="@dimen/_8dp"
                        android:layout_height="@dimen/_8dp"
                        android:layout_marginHorizontal="@dimen/_10dp"
                        android:background="@drawable/bg_intro_dot_selected"/>

                    <View
                        android:id="@+id/indicator3"
                        android:layout_width="@dimen/_8dp"
                        android:layout_height="@dimen/_8dp"
                        android:background="@drawable/bg_intro_dot_selected"/>
                </androidx.appcompat.widget.LinearLayoutCompat>

                <TextView
                    android:layout_width="wrap_content"
                    android:textColor="#9747FF"
                    android:layout_gravity="end|bottom"
                    android:layout_marginBottom="@dimen/_17dp"
                    android:layout_marginEnd="@dimen/_10dp"
                    android:textSize="@dimen/_16dp"
                    android:paddingVertical="@dimen/_3dp"
                    android:paddingHorizontal="@dimen/_12dp"
                    android:id="@+id/tvNextBottom"
                    android:background="@drawable/bg_transparent_ripple_media_shape"
                    android:text="@string/common_next"
                    android:fontFamily="@font/roboto_medium"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
        </androidx.appcompat.widget.LinearLayoutCompat>

        <View
            android:background="@drawable/bg_intro_text_dark"
            android:layout_width="match_parent"
            android:layout_height="180dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/_50dp"
            android:id="@+id/tvTitle"
            android:text="@string/core_onboarding_title_2"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="@dimen/_24dp"
            android:gravity="center"
            android:layout_marginHorizontal="@dimen/_10dp"
            android:layout_height="wrap_content"/>

    </FrameLayout>



</androidx.appcompat.widget.LinearLayoutCompat>
